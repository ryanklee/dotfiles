[
    {
        "layer": "top",
        "position": "top",
        "output": "DP-2",
        "height": 28,
        "margin-top": 4,
        "margin-left": 6,
        "margin-right": 6,
        "spacing": 0,

        "modules-left": [
            "hyprland/workspaces",
            "hyprland/submap",

            "mpris",
            "custom/build"
        ],
        "modules-center": [
            "hyprland/window"
        ],
        "modules-right": [
            "custom/working-mode",
            "custom/hapax-status",
            "custom/gpu",
            "temperature",
            "cpu",
            "memory",
            "disk",
            "disk#store",
            "disk#data",
            "custom/docker",
            "pulseaudio",
            "pulseaudio#mic",
            "privacy",
            "network",
            "custom/tailscale",
            "idle_inhibitor",
            "systemd-failed-units",
            "custom/notification",
            "custom/dismiss-notifs",
            "custom/clipboard",
            "custom/weather",
            "clock",
            "tray"
        ],

        "hyprland/workspaces": {
            "format": "{id}",
            "persistent-workspaces": { "DP-2": [1, 2, 3, 4, 5] },
            "sort-by-number": true
        },
        "hyprland/submap": {
            "format": " {s}",
            "tooltip": false
        },
        "hyprland/window": {
            "max-length": 50,
            "separate-outputs": true
        },
        "mpris": {
            "format": " {artist} - {title}",
            "format-paused": " {artist} - {title}",
            "max-length": 35,
            "interval": 3,
            "on-click": "playerctl play-pause",
            "on-scroll-up": "playerctl next",
            "on-scroll-down": "playerctl previous",
            "ignored-players": ["firefox"]
        },
        "clock": {
            "format": "箚쪛 {:%H:%M}",
            "format-alt": "箚쪛 {:%m-%d %H:%M:%S}",
            "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
            "interval": 60
        },
        "temperature": {
            "hwmon-path-abs": "/sys/devices/pci0000:00/0000:00:18.3/hwmon",
            "input-filename": "temp1_input",
            "critical-threshold": 85,
            "format": "箚뵋 {temperatureC}째",
            "format-critical": "箚툈 {temperatureC}째",
            "interval": 10,
            "tooltip-format": "<b>CPU Tctl</b>: {temperatureC}째C"
        },
        "cpu": {
            "format": "箚삖 {usage}%",
            "interval": 10,
            "tooltip-format": "<b>CPU</b>\n{avg_frequency} GHz\n{usage}% usage\nLoad: {load}",
            "on-click": "foot -e htop",
            "on-click-right": "foot -e btop"
        },
        "memory": {
            "format": "箚뜘 {percentage}%",
            "interval": 5,
            "tooltip-format": "<b>Memory</b>\n{used:0.1f}G / {total:0.1f}G\n{swapUsed:0.1f}G swap",
            "on-click": "foot -e htop"
        },
        "disk": {
            "format": "箚땴 {percentage_used}%",
            "path": "/",
            "interval": 60,
            "states": { "warning": 80, "critical": 90 },
            "tooltip-format": "<b>Root /</b>\n{used} / {total}\n{percentage_used}% used\n{free} free"
        },
        "disk#store": {
            "format": "箚뿮 {percentage_used}%",
            "path": "/store",
            "interval": 60,
            "states": { "warning": 70, "critical": 85 },
            "tooltip-format": "<b>/store (LLM data)</b>\nQdrant, Postgres, ClickHouse, Prometheus, Grafana\n{used} / {total}\n{percentage_used}% used\n{free} free"
        },
        "disk#data": {
            "format": "茶겳 {percentage_used}%",
            "path": "/data",
            "interval": 120,
            "states": { "warning": 80, "critical": 90 },
            "tooltip-format": "<b>/data</b>\n{used} / {total}\n{percentage_used}% used\n{free} free"
        },
        "custom/gpu": {
            "exec": "~/.local/bin/waybar-scripts/gpu-status.sh",
            "return-type": "json",
            "format": "箚쓰 {}",
            "interval": 10,
            "on-click": "foot -e nvtop",
            "tooltip": true
        },
        "custom/docker": {
            "exec": "~/.local/bin/waybar-scripts/docker-status.sh",
            "return-type": "json",
            "format": " {}",
            "interval": 15,
            "on-click": "foot -e bash -c 'docker ps -a --format \"table {{.Names}}\\t{{.Status}}\\t{{.Ports}}\"; echo; read -p \"Press enter...\"'"
        },
        "pulseaudio": {
            "format": "箚빢 {volume}%",
            "format-muted": "箚뻶 mute",
            "on-click": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
            "on-click-right": "pwvucontrol &disown",
            "on-scroll-up": "wpctl set-volume -l 1.0 @DEFAULT_AUDIO_SINK@ 2%+",
            "on-scroll-down": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 2%-",
            "tooltip-format": "<b>Output</b>: {desc}\nVolume: {volume}%"
        },
        "pulseaudio#mic": {
            "format": "{format_source}",
            "format-source": "箚뜫 {volume}%",
            "format-source-muted": "箚뜭 mute",
            "on-click": "wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle",
            "on-scroll-up": "wpctl set-volume -l 1.0 @DEFAULT_AUDIO_SOURCE@ 2%+",
            "on-scroll-down": "wpctl set-volume @DEFAULT_AUDIO_SOURCE@ 2%-",
            "tooltip-format": "<b>Mic</b>: {source_desc}\nVolume: {source_volume}%"
        },
        "network": {
            "format-ethernet": "箚쎋 {ipaddr}",
            "format-wifi": "箚ㄸ {essid} {signalStrength}%",
            "format-disconnected": "箚ㄽ --",
            "tooltip-format": "<b>{ifname}</b>\n{ipaddr}/{cidr}\n {bandwidthUpBits}   {bandwidthDownBits}",
            "interval": 5,
            "on-click": "nm-connection-editor",
            "on-click-right": "foot -e nmtui"
        },
        "custom/tailscale": {
            "exec": "~/.local/bin/waybar-scripts/tailscale-status.sh",
            "return-type": "json",
            "format": "箚뭵 {}",
            "interval": 10,
            "on-click": "tailscale up",
            "on-click-right": "tailscale down"
        },
        "idle_inhibitor": {
            "format": "{icon}",
            "format-icons": {
                "activated": "",
                "deactivated": ""
            },
            "tooltip-format-activated": "Idle inhibitor: <b>ON</b>\nScreen will not lock",
            "tooltip-format-deactivated": "Idle inhibitor: off"
        },
        "privacy": {
            "icon-spacing": 4,
            "icon-size": 14,
            "transition-duration": 250,
            "modules": [
                {"type": "screenshare", "tooltip": true, "tooltip-icon-size": 16},
                {"type": "audio-in", "tooltip": true, "tooltip-icon-size": 16}
            ]
        },
        "systemd-failed-units": {
            "format": " {nr_failed}",
            "format-ok": "",
            "hide-on-ok": true,
            "user": true
        },
        "custom/notification": {
            "tooltip": false,
            "format": "{}",
            "return-type": "json",
            "exec-if": "which makoctl",
            "exec": "~/.local/bin/waybar-scripts/mako-status.sh",
            "on-click": "makoctl invoke",
            "on-click-right": "makoctl mode -t do-not-disturb",
            "interval": 5,
            "signal": 2
        },
        "custom/clipboard": {
            "exec": "~/.local/bin/waybar-scripts/cliphist-count.sh",
            "return-type": "json",
            "format": "箚뀋 {}",
            "interval": 10,
            "on-click": "cliphist list | fuzzel -d -p 'Clipboard: ' | cliphist decode | wl-copy",
            "on-click-right": "cliphist wipe"
        },
        "custom/weather": {
            "exec": "~/.local/bin/waybar-scripts/weather.sh",
            "return-type": "json",
            "format": "{}",
            "interval": 3600,
            "tooltip": true
        },
        "custom/build": {
            "exec": "~/.local/bin/waybar-scripts/build-status.sh",
            "return-type": "json",
            "format": "{}",
            "interval": 10,
            "on-click": "journalctl --user -u hapax-build-reload.service -u hapax-rebuild-logos.service --since '1 hour ago' --no-pager | tail -30 | foot -e less",
            "on-click-right": "systemctl --user start hapax-rebuild-logos.service"
        },
        "custom/hapax-status": {
            "exec": "~/.local/bin/waybar-scripts/hapax-status.sh",
            "return-type": "json",
            "format": "{}",
            "interval": 30,
            "signal": 1,
            "on-click": "xdg-open http://localhost:8051",
            "on-click-right": "xdg-open http://localhost:3000"
        },
        "custom/dismiss-notifs": {
            "format": "箚뀟",
            "tooltip": "Dismiss all notifications",
            "on-click": "makoctl dismiss --all"
        },
        "custom/working-mode": {
            "exec": "~/.local/bin/waybar-scripts/working-mode.sh",
            "return-type": "json",
            "format": "{}",
            "interval": 30,
            "signal": 10,
            "on-click": "~/.local/bin/hapax-working-mode $([ $(~/.local/bin/hapax-working-mode) = rnd ] && echo research || echo rnd)"
        },
        "tray": {
            "icon-size": 14,
            "spacing": 4
        }
    },
    {
        "layer": "top",
        "position": "top",
        "output": "DP-1",
        "height": 28,
        "margin-top": 4,
        "margin-left": 6,
        "margin-right": 6,
        "spacing": 0,

        "modules-left": [
            "hyprland/workspaces",
            "hyprland/submap",

            "mpris",
            "custom/build"
        ],
        "modules-center": [
            "hyprland/window"
        ],
        "modules-right": [
            "custom/working-mode",
            "custom/hapax-status",
            "custom/gpu",
            "temperature",
            "cpu",
            "memory",
            "disk",
            "disk#store",
            "disk#data",
            "custom/docker",
            "pulseaudio",
            "pulseaudio#mic",
            "privacy",
            "network",
            "custom/tailscale",
            "idle_inhibitor",
            "systemd-failed-units",
            "custom/notification",
            "custom/dismiss-notifs",
            "custom/clipboard",
            "custom/weather",
            "clock",
            "tray"
        ],

        "hyprland/workspaces": {
